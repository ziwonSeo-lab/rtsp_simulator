# ===========================================
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
cover.out
cover.html
cpu.prof
mem.prof

# ===========================================
# Build Artifacts & Distribution
# ===========================================
build/
dist/
*.egg-info/
*.egg

