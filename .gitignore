.pytest_cache/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.ruff_cache/
*.db
*.sqlite
*.sqlite3
*.rdb
*.dbm

# ===========================================
# Virtual Environments
# ===========================================
venv/
.venv/
env/
.env/
.uv_cache/
.uv-cache/

# ===========================================
# Test Coverage
# ===========================================
.coverage
coverage.json
htmlcov/

